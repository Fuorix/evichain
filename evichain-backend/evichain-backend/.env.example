# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# ─── Ethereum / Blockchain ────────────────────────────────────────────────────
# Infura:  https://app.infura.io  → Create Project → Copy Sepolia HTTPS URL
# Alchemy: https://alchemy.com    → Create App → Copy HTTPS URL
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Export from MetaMask: Account Details → Export Private Key (NEVER commit!)
PRIVATE_KEY=your-private-key-here

# Fill this AFTER running: npm run deploy:chain  (or deploying via Remix)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Firebase / Firestore ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
# Option A: paste ONLY the PEM private key (escaped newlines required)
FIREBASE_PRIVATE_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"your-key-id","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project-id.iam.gserviceaccount.com","client_id":"000000000000000000000","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40your-project-id.iam.gserviceaccount.com","universe_domain":"googleapis.com"}
# Option B: paste full service account JSON as a single-line JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_DATABASE_URL=
FIREBASE_AUTH_COLLECTION=auth_events
FIREBASE_EVIDENCE_COLLECTION=evidence_metadata

# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
# Free account at https://pinata.cloud → API Keys → New Key
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
